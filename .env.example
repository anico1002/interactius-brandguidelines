# Supabase — Deck Maker persistence (project "brand-guidelines", org Interactius, eu-central-2)
# Copy to .env.local and fill with the project's API credentials (Supabase dashboard → Project Settings → API).
# In production, set these as Netlify environment variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Claude API — used by /api/translate to translate decks (server-side only; never exposed).
ANTHROPIC_API_KEY=

# Resend — best-effort "aviso automático" email when a client signs a deck (/api/sign).
# All optional: without them the signature is still persisted, just no email is sent.
RESEND_API_KEY=
INTERACTIUS_NOTIFY_EMAIL=        # recipient(s) of the notice; comma-separated
RESEND_FROM=                     # verified sender, e.g. "Interactius <propuestas@interactius.com>"
